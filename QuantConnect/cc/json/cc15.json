          "label": "Regime",
          "text": "BB(20, 2σ) %B(QQQ)"
        },
        {
          "label": "Entry",
          "text": "%B > 0.65 → 100% TQQQ"
        },
        {
          "label": "Exit",
          "text": "%B < 0.35 → 100% BIL"
        },
        {
          "label": "Hold",
          "text": "0.35 ≤ %B ≤ 0.65 → no change"
        },
        {
          "label": "Symbols",
          "text": "Signal: QQQ. Execution: TQQQ / BIL"
        },
        {
          "label": "Rebalance",
          "text": "Daily, 30 min after market open"
        }
