          "label": "Entry",
          "text": "%B > 0.5 → 20% in each of top-5 mega-caps"
        },
        {
          "label": "Exit",
          "text": "%B < 0.4 → 100% BIL"
        },
        {
          "label": "Symbols",
          "text": "Signal: QQQ. Execution: top-5 mega-caps / BIL"
        },
        {
          "label": "Rebalance",
          "text": "Daily, 30 min after market open"
        }
      ]
