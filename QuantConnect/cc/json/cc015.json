    "576": {
      "name": "BB_PctB50 (cc15_576.py)",
      "file": "cc015_001.py",
      "category": "Volatility",
      "overfit": "2/10",
      "algo_dir": "cc_algos",
      "vault_path": "vault://QuantConnect/cc/cc_algos/cc015_001.py",
      "source": "cc15 batch 1 BB",
      "description": "Bollinger Band trend follower on QQQ — when %B sits above the midpoint (price above the SMA mid-band), goes long leveraged Nasdaq; below the midpoint, sits in cash equivalents. Single-threshold binary regime switch with no hysteresis.",
      "overfit_notes": "Single BB(20,2) %B>0.5 threshold — canonical Bollinger settings; %B midpoint test is symmetric and untuned.",
      "rules": [
        {
          "label": "Regime",
          "text": "BB(20, 2σ) %B(QQQ)"
        },
        {
          "label": "Entry",
          "text": "%B > 0.5 → 100% TQQQ"
        },
        {
          "label": "Exit",
          "text": "%B ≤ 0.5 → 100% BIL"
        },
        {
          "label": "Symbols",
          "text": "Signal: QQQ. Execution: TQQQ / BIL"
        },
        {
          "label": "Rebalance",
          "text": "Daily, 30 min after market open"
        }
      ]
    },
    "577": {
      "name": "BB_PctB65 (cc15_577.py)",
      "file": "cc015_002.py",
      "category": "Volatility",
      "overfit": "2/10",
      "algo_dir": "cc_algos",
      "vault_path": "vault://QuantConnect/cc/cc_algos/cc015_002.py",
      "source": "cc15 batch 1 BB",
      "description": "Bollinger %B trend follower on QQQ with a hysteresis band — enters TQQQ only when %B pushes above 0.65 and exits to cash only when %B drops below 0.35. Holds position inside the 0.35–0.65 dead zone to reduce whipsaw.",
      "overfit_notes": "Adds two asymmetric thresholds (0.35 / 0.65) around the midpoint to BB(20,2). The dead-zone design is a reasonable anti-churn pattern; cutoffs are slightly tuned.",
      "rules": [
        {
          "label": "Regime",
          "text": "BB(20, 2σ) %B(QQQ)"
        },
        {
          "label": "Entry",
          "text": "%B > 0.65 → 100% TQQQ"
        },
        {
          "label": "Exit",
          "text": "%B < 0.35 → 100% BIL"
        },
        {
          "label": "Hold",
          "text": "0.35 ≤ %B ≤ 0.65 → no change"
        },
        {
          "label": "Symbols",
          "text": "Signal: QQQ. Execution: TQQQ / BIL"
        },
        {
          "label": "Rebalance",
          "text": "Daily, 30 min after market open"
        }
      ]
    },
